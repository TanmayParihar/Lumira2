# ═══════════════════════════════════════════════════════════
#  Lumira Intelligence Pipeline — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy to .env and fill in your values

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=lumira
POSTGRES_PASSWORD=lumira_secret
POSTGRES_DB=lumira

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── OpenSearch ────────────────────────────────────────────
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200

# ── MinIO ─────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=false

# ── Nominatim (local) ─────────────────────────────────────
NOMINATIM_URL=http://localhost:8080
# Set to true to fall back to OSM public API when local is down
GEOCODE_FALLBACK_ONLINE=true

# ── Ollama (local LLM server) ─────────────────────────────
OLLAMA_URL=http://localhost:11434
TEXT_MODEL=qwen3.5:4b
VISION_MODEL=qwen3-vl:4b

# ── Whisper ───────────────────────────────────────────────
# Sizes: tiny | base | small | medium | large-v3
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
# Compute type: int8 (CPU) | float16 (GPU)
WHISPER_COMPUTE_TYPE=int8

# ── External API Keys ─────────────────────────────────────
NEWSAPI_KEY=your_newsapi_key_here
SERPER_API_KEY=your_serper_key_here

# Optional: Telegram OSINT (leave blank to disable)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ── Intelligence Tuning ───────────────────────────────────
DTI_WINDOW_HOURS=24
DTI_UPDATE_INTERVAL_MINUTES=30
ANOMALY_ZSCORE_THRESHOLD=2.5
ANOMALY_LOOKBACK_DAYS=30
PROXIMITY_ALERT_DEFAULT_KM=5.0
EVENT_FUSION_SIMILARITY_THRESHOLD=0.85
EVENT_DEDUP_WINDOW_HOURS=2

# ── App ───────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
MEDIA_BASE_PATH=./media
